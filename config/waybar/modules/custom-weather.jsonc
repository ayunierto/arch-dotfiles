{
  "custom/weather": {
    "exec": "${HOME}/.config/waybar/scripts/get_weather.sh Chiclayo+Peru",
    "return-type": "json",
    "format": "  {}",
    "tooltip": true,
    "interval": 3600,
    "on-click": "kitty --hold --class center-float fish -c 'curl wttr.in/Chiclayo+Peru'"
  }
}
